<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Monitor" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Background colors -->
        <item name="android:windowBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Custom styles for modernization -->
        <item name="materialButtonStyle">@style/Widget.Monitor.Button</item>
        <item name="textInputStyle">@style/Widget.Monitor.TextInputLayout</item>
    </style>
</resources>